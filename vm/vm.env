# ZephyrOS VM defaults for QEMU/KVM + OVMF (Secure Boot)
#
# All values can be overridden by exporting the same variables before calling
# run-vm.sh, or by editing this file.

# Memory and CPU
VM_RAM_MB=4096
VM_CPUS=2

# Disk image (created automatically if missing)
VM_DISK_IMAGE="zephyros-vm.qcow2"
VM_DISK_GB=32

# UEFI firmware (OVMF with Secure Boot support)
# These paths may differ per distro; adjust as needed.
# Common locations:
#   Arch:   /usr/share/OVMF/OVMF_CODE.secboot.fd
#   Debian: /usr/share/OVMF/OVMF_CODE_4M.secboot.fd
#   Fedora: /usr/share/edk2/ovmf/OVMF_CODE.secboot.fd
VM_UEFI_CODE="/usr/share/OVMF/OVMF_CODE.secboot.fd"
VM_UEFI_VARS="./OVMF_VARS.secboot.fd"

# Display backend (e.g. gtk, sdl)
VM_DISPLAY="gtk"

# Extra QEMU options (optional)
VM_EXTRA_ARGS=""

