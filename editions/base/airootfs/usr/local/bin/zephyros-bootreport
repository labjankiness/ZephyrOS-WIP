#!/usr/bin/env bash
#
# zephyros-bootreport — Wrap systemd-analyze and surface the noisy units.
#
# Writes a Markdown report with:
#   - overall boot timing
#   - critical chain
#   - top 20 slowest units (blame)
#   - failed units
#   - unit-file start counts since boot
#
# Usage:
#   zephyros-bootreport                     # stdout
#   zephyros-bootreport -o boot.md          # file
#   zephyros-bootreport --threshold 500ms   # flag units over threshold
#
set -u

OUTPUT=""
THRESHOLD="500ms"

while [ "$#" -gt 0 ]; do
    case "$1" in
        -o|--output)    OUTPUT="${2:-}"; shift 2 ;;
        --threshold)    THRESHOLD="${2:-500ms}"; shift 2 ;;
        -h|--help)      sed -n '3,15p' "$0"; exit 0 ;;
        *)              printf 'Unknown argument: %s\n' "$1" >&2; exit 2 ;;
    esac
done

if ! command -v systemd-analyze >/dev/null 2>&1; then
    echo "systemd-analyze not available (not running under systemd?)" >&2
    exit 1
fi

emit() {
    printf '# ZephyrOS boot report\n\n'
    printf -- '- Generated: %s\n' "$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
    printf -- '- Kernel: %s\n' "$(uname -sr)"
    printf -- '- Threshold for "slow": %s\n\n' "$THRESHOLD"

    printf '## Overall timing\n\n```\n'
    systemd-analyze 2>&1 || true
    printf '```\n\n'

    printf '## Critical chain\n\n```\n'
    systemd-analyze critical-chain 2>&1 | head -40 || true
    printf '```\n\n'

    printf '## Slowest units (top 20)\n\n```\n'
    systemd-analyze blame 2>&1 | head -20 || true
    printf '```\n\n'

    printf '## Units slower than %s\n\n```\n' "$THRESHOLD"
    # Convert threshold to milliseconds for comparison.
    # Accepts forms like "500ms", "1s", "1.5s".
    tnum=$(printf '%s' "$THRESHOLD" | sed -E 's/([0-9.]+)(ms|s)/\1 \2/')
    set -- $tnum
    case "${2:-ms}" in
        s)  tms=$(awk -v n="$1" 'BEGIN{printf "%d", n*1000}') ;;
        ms) tms=$(awk -v n="$1" 'BEGIN{printf "%d", n}') ;;
        *)  tms=500 ;;
    esac
    systemd-analyze blame 2>/dev/null | awk -v t="$tms" '
        {
            line=$0
            dur=$1
            # Normalize: Xmin Ys Zms combinations
            ms=0
            while (match(dur, /[0-9.]+(min|s|ms)/)) {
                tok=substr(dur, RSTART, RLENGTH)
                val=tok+0
                if (tok ~ /min$/) ms += val*60000
                else if (tok ~ /ms$/) ms += val
                else ms += val*1000
                dur=substr(dur, RSTART+RLENGTH)
                if (dur=="") break
            }
            if (ms >= t) print line
        }' || true
    printf '```\n\n'

    printf '## Failed units\n\n```\n'
    systemctl --failed --no-legend 2>&1 || true
    printf '```\n\n'

    printf '## Suggestions\n\n'
    FAILS=$(systemctl --failed --no-legend 2>/dev/null | wc -l)
    if [ "$FAILS" -gt 0 ]; then
        printf -- '- %s failed unit(s) — inspect with `systemctl status <unit>` and `journalctl -u <unit>`.\n' "$FAILS"
    fi
    if systemd-analyze blame 2>/dev/null | head -5 | grep -qE '(NetworkManager-wait-online|systemd-networkd-wait-online)'; then
        printf -- '- A network-wait-online unit is in the slow list. Consider `systemctl disable NetworkManager-wait-online.service` unless something explicitly needs blocking on the network.\n'
    fi
    if systemd-analyze blame 2>/dev/null | head -5 | grep -q 'plymouth-quit-wait'; then
        printf -- '- Plymouth quit-wait is slow. If not using a splash, remove the plymouth plug.\n'
    fi
    printf -- '- Compare against baseline by saving this file after each boot-time change.\n'
}

if [ -n "$OUTPUT" ]; then
    emit > "$OUTPUT"
    printf 'Wrote boot report to %s\n' "$OUTPUT" >&2
else
    emit
fi
