# =============================================================================
# ZephyrOS Base Packages — shared across all editions
# =============================================================================

# --- Base system ---
base
mkinitcpio
mkinitcpio-archiso
systemd

# --- Kernel & firmware ---
linux
linux-firmware
sof-firmware
# CPU microcode — GRUB picks the right one at boot
intel-ucode
amd-ucode

# --- Boot ---
grub
efibootmgr
sbsigntools
efitools
mokutil

# --- Wayland & compositor ---
wayland
labwc
xorg-server-xwayland

# --- Launcher ---
wofi

# --- Display & GPU ---
mesa
vulkan-radeon
vulkan-intel
vulkan-nouveau
vulkan-icd-loader
libva-mesa-driver
libva-intel-driver
intel-media-driver
mesa-vdpau
libva-utils
vdpauinfo
virglrenderer
# Nvidia path — users with Nvidia cards can install nvidia/nvidia-utils post-install;
# shipping nouveau + firmware is enough for boot on all three GPU vendors.
xf86-video-vesa

# --- Fonts ---
inter-font
noto-fonts
noto-fonts-emoji

# --- File manager ---
thunar
gvfs

# --- Terminal ---
kitty

# --- Shell ---
zsh
zsh-completions

# --- GTK theming (AUR packages built via local repo) ---
adw-gtk3
fluent-icon-theme-git

# --- Audio ---
pipewire
pipewire-pulse
wireplumber

# --- Networking ---
networkmanager
network-manager-applet
# Wi-Fi / Bluetooth
iw
wireless-regdb
wpa_supplicant
bluez
bluez-utils
# Optional proprietary Wi-Fi firmware (Broadcom wl is AUR; document in hardware guide)

# --- Power management (Phase 3) ---
# TLP handles laptop power tuning. thermald throttles Intel CPUs to prevent thermal
# runaway. upower exposes battery state to the desktop.
tlp
tlp-rdw
thermald
upower
acpi
acpid
# Suspend/hibernate helpers
pm-utils

# --- Flatpak ---
flatpak
xdg-desktop-portal
xdg-desktop-portal-wlr

# --- VM guest utilities ---
qemu-guest-agent
spice-vdagent

# --- Installer dependencies ---
arch-install-scripts
dialog
gptfdisk
dosfstools
e2fsprogs
parted

# --- AI runtime (shared across all AI editions) ---
ollama
